# 复制为 .env 后填写

# 当前默认 provider：openai / deepseek / bailian / glm
DEFAULT_PROVIDER=bailian

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_INPUT_PRICE_PER_MILLION=
OPENAI_OUTPUT_PRICE_PER_MILLION=

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_INPUT_PRICE_PER_MILLION=
DEEPSEEK_OUTPUT_PRICE_PER_MILLION=

# 阿里云百炼 / 通义
BAILIAN_API_KEY=
BAILIAN_BASE_URL=
BAILIAN_MODEL=qwen-plus
BAILIAN_INPUT_PRICE_PER_MILLION=
BAILIAN_OUTPUT_PRICE_PER_MILLION=

# GLM
GLM_API_KEY=
GLM_BASE_URL=
GLM_MODEL=glm-4.5-air
GLM_INPUT_PRICE_PER_MILLION=
GLM_OUTPUT_PRICE_PER_MILLION=
