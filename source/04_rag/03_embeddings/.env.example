# 复制为 .env 后填写
#
# 04_real_embeddings.py 实际使用的是 embeddings 配置，不是 chat completions 配置。
# 推荐优先填写 EMBEDDING_*；如果没有填写，会按 DEFAULT_PROVIDER 兼容读取
# BAILIAN_* / OPENAI_* / DEEPSEEK_* / GLM_* 中的连接信息。

# 本章推荐配置：直接指定 embeddings endpoint
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

# 可选：如果你想提前固定向量维度，可以填写；为空时脚本会用首次响应自动记录维度。
EMBEDDING_DIMENSIONS=

# 兼容旧章节 provider 配置，可选：bailian / deepseek / glm / openai
DEFAULT_PROVIDER=bailian

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_API_KEY=
OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BACKUP_PROVIDER=
OPENAI_INPUT_PRICE_PER_MILLION=
OPENAI_OUTPUT_PRICE_PER_MILLION=

# DeepSeek
# 注意：DeepSeek 的 chat 配置保留为兼容旧章节；是否支持 embeddings 取决于你当前使用的平台服务。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_EMBEDDING_API_KEY=
DEEPSEEK_EMBEDDING_BASE_URL=
DEEPSEEK_EMBEDDING_MODEL=
DEEPSEEK_BACKUP_PROVIDER=bailian
DEEPSEEK_INPUT_PRICE_PER_MILLION=
DEEPSEEK_OUTPUT_PRICE_PER_MILLION=

# Bailian / Qwen
BAILIAN_API_KEY=
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen-plus
BAILIAN_EMBEDDING_API_KEY=
BAILIAN_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_EMBEDDING_MODEL=text-embedding-v4
BAILIAN_BACKUP_PROVIDER=deepseek
BAILIAN_INPUT_PRICE_PER_MILLION=
BAILIAN_OUTPUT_PRICE_PER_MILLION=

# GLM
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_MODEL=glm-4.5-air
GLM_EMBEDDING_API_KEY=
GLM_EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_EMBEDDING_MODEL=
GLM_BACKUP_PROVIDER=bailian
GLM_INPUT_PRICE_PER_MILLION=
GLM_OUTPUT_PRICE_PER_MILLION=
