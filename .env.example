OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://...              # OpenAI 兼容平台时填写（见下方 DeepSeek 示例）
OPENAI_MODEL=gpt-4o-mini
# OPENAI_STRUCTURED_MODEL=gpt-4o           # chat.structured_chat 使用
# OPENAI_FALLBACK_MODEL=gpt-4o-mini        # chat.fallback_chat 使用

# DeepSeek 示例（取消注释并填入 Key 即可，无需改代码）：
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-chat
# OPENAI_STRUCTURED_MODEL=deepseek-chat
